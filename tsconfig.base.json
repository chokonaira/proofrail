{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@permitrail/core": ["packages/core/src/index.ts"],
      "@permitrail/provider-local": ["packages/local-provider/src/index.ts"],
      "@permitrail/mcp-gateway": ["packages/mcp-gateway/src/index.ts"],
      "@permitrail/mcp": ["packages/mcp/src/index.ts"],
      "@permitrail/provider-webhook": ["packages/webhook-provider/src/index.ts"],
      "@permitrail/local-approval": ["packages/local-approval/src/index.ts"]
    }
  }
}
