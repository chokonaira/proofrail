{
  "name": "permitrail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source permission and proof gateway for AI agent tool calls.",
  "license": "Apache-2.0",
  "author": "Henry Okonkwo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chokonaira/permitrail.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "ai-agents",
    "mcp",
    "agent-security",
    "agent-safety",
    "proofs",
    "permission-layer",
    "human-approval",
    "audit-trail"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo site/vendor",
    "build:sandbox": "npm run build && rm -rf site/vendor && mkdir -p site/vendor/core site/vendor/gateway site/vendor/provider && cp packages/core/dist/*.js site/vendor/core/ && cp packages/mcp-gateway/dist/*.js site/vendor/gateway/ && cp packages/local-provider/dist/*.js site/vendor/provider/",
    "docs:api": "typedoc",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --conditions=development --experimental-strip-types --test \"packages/**/*.test.ts\" \"examples/**/*.test.ts\"",
    "demo": "node --conditions=development --experimental-strip-types examples/restricted-action-agent/demo.ts",
    "check": "npm run typecheck && npm run test && npm run demo",
    "prepack": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  }
}
