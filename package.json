{
  "name": "permitrail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source permission and proof gateway for AI agent tool calls.",
  "license": "Apache-2.0",
  "author": "Henry Okonkwo",
  "repository": {
    "type": "git",
    "url": "https://github.com/chokonaira/permitrail.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "ai-agents",
    "mcp",
    "agent-security",
    "agent-safety",
    "proofs",
    "permission-layer",
    "human-approval",
    "audit-trail"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --conditions=development --experimental-strip-types --test \"packages/**/*.test.ts\" \"examples/**/*.test.ts\"",
    "demo": "node --conditions=development --experimental-strip-types examples/restricted-action-agent/demo.ts",
    "check": "npm run typecheck && npm run test && npm run demo",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  }
}
